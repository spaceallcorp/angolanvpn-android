<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- O grupo permite alterar o tamanho de todo o interior de forma simples -->
    <group
        android:pivotX="12"
        android:pivotY="12"
        android:scaleX="1.0"
        android:scaleY="1.15">

        <!-- Triângulo com cantos perfeitamente arredondados -->
        <path
            android:pathData="M 6.5,6.5 Q 8,3.5 9.5,6.5 L 14.5,16.5 Q 16,19.5 13,19.5 L 3,19.5 Q 0,19.5 1.5,16.5 Z"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="2"
            android:fillColor="#00000000"
            android:strokeLineJoin="round" />

        <!-- Círculo sobreposto à direita -->
        <path
            android:pathData="M 16,7 a 6,6 0 1,0 0,12 a 6,6 0 1,0 0,-12"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="2"
            android:fillColor="#00000000" />
    </group>
</vector>
